{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    /* Base options */
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "lib": ["DOM", "DOM.Iterable", "ES2024"],
    "types": ["vite/client"],
    /* For React app */
    "jsx": "react-jsx"
  },
  "include": [
    "src" // include every source file (like test files etc.) in the compilation (type-checking) because Vite builds the project
  ]
}
