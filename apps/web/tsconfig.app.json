{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    /* Base options */
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "noEmit": true, // tsc won't emit compiled JS output because Vite builds the project
    "target": "es2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2024",
    ],
    "types": [
      "vite/client"
    ],
    /* For React app */
    "jsx": "react-jsx",
  },
  "include": [
    "src" // include every source file (like test files etc.) in the compilation (type-checking) because Vite builds the project
  ]
}
